---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';
import { getPublishedPosts, formatDate } from '../../utils/content';

const posts = await getPublishedPosts();

const byYear = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const y = String(post.data.pubDate.getUTCFullYear());
  (acc[y] ||= []).push(post);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${SITE.title} — Blog`,
  url: new URL('/blog', SITE.url).toString(),
  inLanguage: SITE.locale,
  author: { '@type': 'Person', name: SITE.author, url: SITE.url },
  blogPost: posts.slice(0, 20).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    url: new URL(`/blog/${p.id}`, SITE.url).toString(),
    datePublished: p.data.pubDate.toISOString(),
  })),
};
---

<BaseLayout
  title="Blog"
  description={`${SITE.author} — yazılar, denemeler, notlar.`}
  jsonLd={blogLd}
>
  <section class="wrap--wide blog-head">
    <p class="eyebrow"><em>Dizin</em></p>
    <h1 class="blog-head__title">Blog</h1>
    <p class="blog-head__sub">
      <em>Ters kronolojik.</em>
      <span class="muted">
        {posts.length} yazı · {years.length} yıl
        {years.length > 0 && ` · ${years[years.length - 1]}—${years[0]}`}
      </span>
    </p>
  </section>

  {posts.length === 0 ? (
    <section class="wrap--wide">
      <p class="muted"><em>Henüz yazı yok.</em></p>
    </section>
  ) : (
    <div class="wrap--wide blog-body">
      {years.map((year) => (
        <section class="year">
          <header class="year__head">
            <h2 class="year__num"><em>{year}</em></h2>
            <span class="year__count">
              {String(byYear[year].length).padStart(2, '0')} yazı
            </span>
          </header>
          <ul class="archive" role="list">
            {byYear[year].map((post) => {
              const date = formatDate(post.data.pubDate, 'tr-TR');
              return (
                <li class="archive__item">
                  <a class="archive__link" href={`/blog/${post.id}`}>
                    <time class="archive__date" datetime={date.iso}>
                      {new Intl.DateTimeFormat('tr-TR', {
                        day: '2-digit',
                        month: 'short',
                      }).format(post.data.pubDate)}
                    </time>
                    <div class="archive__main">
                      <span class="archive__title">{post.data.title}</span>
                      {post.data.description && (
                        <span class="archive__desc">
                          {post.data.description}
                        </span>
                      )}
                    </div>
                    <span class="archive__arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .blog-head {
    padding-block: clamp(3rem, 7vw, 6rem) clamp(1rem, 3vw, 2rem);
  }

  .blog-head__title {
    font-size: var(--t-7);
    margin: var(--s-3) 0 var(--s-4);
    letter-spacing: -0.035em;
  }

  .blog-head__sub {
    font-family: var(--font);
    font-size: var(--t-1);
    color: var(--ink-soft);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
  }

  .blog-head__sub em {
    font-style: italic;
    color: var(--ink);
  }

  .blog-body {
    padding-block: var(--s-5) 0;
  }

  .year {
    margin-bottom: var(--s-8);
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .year__head {
    position: sticky;
    top: 5.5rem;
    padding-top: 0.6rem;
  }

  .year__num {
    font-family: var(--font);
    font-size: var(--t-6);
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .year__num em {
    font-style: italic;
    color: var(--accent);
  }

  .year__count {
    display: block;
    margin-top: var(--s-2);
    font-family: var(--font);
    font-style: italic;
    font-size: var(--t--1);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .archive {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .archive__item + .archive__item {
    border-top: 1px solid var(--rule);
  }

  .archive__link {
    display: grid;
    grid-template-columns: 4.5rem 1fr 1.5rem;
    gap: 1.2rem;
    align-items: baseline;
    padding: 1rem 0.9rem;
    margin-inline: -0.9rem;
    border-radius: var(--radius-sm);
    background-image: none;
    color: var(--ink);
    transition:
      background var(--t-fast),
      transform var(--t-base);
  }

  .archive__link:hover {
    background: var(--surface-hover);
    transform: translateX(3px);
  }

  .archive__date {
    font-family: var(--font);
    font-size: var(--t--1);
    font-style: italic;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    padding-top: 0.18em;
  }

  .archive__main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .archive__title {
    font-family: var(--font);
    font-size: var(--t-1);
    font-weight: 500;
    line-height: 1.32;
    letter-spacing: -0.012em;
    color: var(--ink);
  }

  .archive__desc {
    font-family: var(--font);
    font-size: var(--t--1);
    color: var(--ink-mute);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .archive__arrow {
    color: var(--muted-soft);
    font-size: var(--t-0);
    transition: color var(--t-fast), transform var(--t-base);
    justify-self: end;
    padding-top: 0.1em;
  }

  .archive__link:hover .archive__arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 42rem) {
    .year {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
    .year__head {
      position: static;
      padding-top: 0;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 0.4rem;
    }
    .year__num {
      font-size: var(--t-5);
    }
    .year__count {
      margin-top: 0;
    }
  }

  @media (max-width: 32rem) {
    .archive__link {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
    .archive__date {
      order: -1;
      font-size: var(--t--2);
    }
    .archive__arrow {
      display: none;
    }
  }
</style>
