      padding:16px;color:var(--ink-soft);font-size:.85rem;text-align:center}
  }

  /* generic info section */
  /* minmax(0,1fr): grid öğesinin min-width:auto'su tabloyu küçültemez, sütun viewport'u aşar */
  .info-grid{display:grid;gap:14px;grid-template-columns:minmax(0,1fr)}
