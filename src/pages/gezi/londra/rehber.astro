  .dday{flex:0 0 auto;background:var(--green);color:#f4efe4;font-size:.72rem;font-weight:700;border-radius:999px;padding:4px 11px;white-space:nowrap}
  .grouplabel{font-family:var(--serif);font-size:1.15rem;font-weight:600;margin:20px 0 10px;color:var(--green-deep);display:flex;align-items:center;gap:9px}
  .grouplabel .dot{width:10px;height:10px;border-radius:50%}
  @media print{
    .map-block iframe{display:none}
