<script is:inline>
  // map leg tabs
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.maptabs button');
    if(!btn) return;
    var block = btn.closest('.map-block');
    var i = [].indexOf.call(btn.parentNode.children, btn);
    block.querySelectorAll('.maptabs button').forEach(function(b,j){ b.classList.toggle('on', j===i); });
    block.querySelectorAll('.mapleg').forEach(function(l,j){ l.classList.toggle('on', j===i); });
  });

  // app bar navigation
  var sheet = document.getElementById('guideSheet');
  var backdrop = document.getElementById('sheetBackdrop');
  var gBtn=document.getElementById('guideBtn');
  function openSheet(){ sheet.classList.add('open'); backdrop.classList.add('open'); gBtn.setAttribute('aria-expanded','true'); }
  function closeSheet(){ sheet.classList.remove('open'); backdrop.classList.remove('open'); gBtn.setAttribute('aria-expanded','false'); }

  document.querySelectorAll('.appbar button[data-target]').forEach(function(b){
    b.addEventListener('click', function(){
      closeSheet();
      var t = document.querySelector(b.getAttribute('data-target'));
      if(t) t.scrollIntoView({behavior:'smooth', block:'start'});
    });
  });
  document.getElementById('guideBtn').addEventListener('click', function(){
    sheet.classList.contains('open') ? closeSheet() : openSheet();
  });
  backdrop.addEventListener('click', closeSheet);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeSheet(); });
  document.querySelectorAll('.maptabs button, .appbar button').forEach(function(b){ b.type='button'; });
  document.querySelectorAll('.sheet-link').forEach(function(a){
    a.addEventListener('click', function(){ setTimeout(closeSheet, 60); });
  });

  // highlight active appbar tab + day-strip pill on scroll
  var spy = [
    {id:'mahalle',btn:0},{id:'lezzet',btn:2},{id:'alisveris',btn:2},
    {id:'g1',btn:1},{id:'g2',btn:1},{id:'g3',btn:1},{id:'g4',btn:1},
    {id:'g5',btn:1},{id:'g6',btn:1},{id:'g7',btn:1},{id:'g8',btn:1},
    {id:'solo',btn:3}
  ];
  var abtns = document.querySelectorAll('.appbar button');
  var stripLinks = document.querySelectorAll('.daystrip a');
  var navLinks = document.querySelectorAll('nav.daynav a');
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){
      if(en.isIntersecting){
        var m = spy.find(function(s){return s.id===en.target.id;});
        if(m){ abtns.forEach(function(b,i){ b.classList.toggle('on', i===m.btn); }); }
        // day-strip highlight
        stripLinks.forEach(function(a){
          a.classList.toggle('on', a.getAttribute('href')==='#'+en.target.id);
        });
        // masaüstü gün nav vurgusu + aktif sekmenin görünür kalması
        navLinks.forEach(function(a){
          var on = a.getAttribute('href')==='#'+en.target.id;
          if(on && !a.classList.contains('on') && a.scrollIntoView){
            try{ a.scrollIntoView({block:'nearest', inline:'center', behavior:'smooth'}); }catch(e){}
          }
          a.classList.toggle('on', on);
        });
      }
    });
  }, {rootMargin:'-45% 0px -50% 0px'});
  spy.forEach(function(s){ var el=document.getElementById(s.id); if(el) io.observe(el); });

  // bilgi çekmecesi; mekân adlarına tıklayınca tarihçe/önem
  var INFO = {
    tower: {k:'Kale · 1078', t:'Tower of London', d:"<p>Fatih William'ın 1078'de yaptırdığı kale; 950 yıl boyunca saray, hazine, darphane ve ünlü bir hapishane olarak kullanıldı. Anne Boleyn burada idam edildi.</p><p><b>Bugün:</b> Kraliyet Mücevherleri (İmparatorluk Tacı dahil), kule kuzgunları ve Tudor üniformalı Beefeater rehberler. Efsaneye göre kuzgunlar kaleyi terk ederse krallık yıkılır.</p>"},
    towerbridge: {k:'Köprü · 1894', t:'Tower Bridge', d:"<p>1894'te açılan, buhar gücüyle çalışan açılır köprü; Viktorya mühendisliğinin şaheseri. Hâlâ yılda ~800 kez gemiler için açılıyor.</p><p><b>Bugün:</b> Üst geçitte cam zeminden 42 m aşağıdaki trafiği izlersiniz; bilete dahil Viktorya dönemi motor odalarında orijinal buhar makineleri duruyor. (London Bridge ile karıştırılır; o, bir sonraki sade köprü.)</p>"},
    borough: {k:'Pazar · ~1014', t:'Borough Market', d:"<p>Londra'nın en eski yiyecek pazarı; kayıtları 1014'e kadar iziliyor; bin yıldır aynı bölgede kurulur. Yeşil demir çatıları Viktorya döneminden.</p><p><b>Bugün:</b> Şehrin gurme kalbi: yüzü aşkın tezgâhta peynirden istiridyeye her şey. Bridget Jones ve Harry Potter sahneleri burada çekildi.</p>"},
    cuttysark: {k:'Yelkenli · 1869', t:'Cutty Sark', d:"<p>1869'da inşa edilen çay kliperi; Çin'den Londra'ya çay taşıyan gemilerin en hızlısıydı; yelkenli çağının son ve en görkemli temsilcisi.</p><p><b>Bugün:</b> Greenwich iskelesinin dibinde kuru havuzda sergileniyor; dışından tüm gövde ve direkleri görülür, içi ve altına girmek biletli.</p>"},
    observatory: {k:'Gözlemevi · 1675', t:'Royal Observatory & Meridyen', d:"<p>II. Charles'ın 1675'te denizcilik için kurdurduğu gözlemevi. Dünyanın boylam sıfır noktası; <b>Başlangıç Meridyeni (0°)</b>: 1884'te burada kabul edildi; küresel saat (GMT) buradan ayarlanır.</p><p><b>Bugün:</b> Avludaki çizgide bir ayağınız doğu, bir ayağınız batı yarım kürede fotoğraf çektirirsiniz. Tepeden Londra silüeti manzarası ücretsizdir; müze kısmı biletli.</p>"},
    greenwichmarket: {k:'Çarşı · 1737', t:'Greenwich Market', d:"<p>1737'den beri kurulan, üstü kapalı zanaat ve yemek pazarı; Londra'nın UNESCO Dünya Mirası alanı içindeki tek tarihî pazarı.</p><p><b>Bugün:</b> El yapımı takı, baskı ve antika tezgâhları + dünya mutfağı büfeleri; yağmurda bile keyifli.</p>"},
    globe: {k:'Tiyatro · 1599/1997', t:"Shakespeare's Globe", d:"<p>Shakespeare'in oyunlarının ilk kez sahnelendiği 1599 tarihli açık havalı tiyatronun, orijinal yerinin 200 m yakınında dönem teknikleriyle (meşe + saz çatı) yapılmış birebir kopyası (1997).</p><p><b>Bugün:</b> Yazın hâlâ gündüz ışığında, mikrofonsuz oyun sahneleniyor. Beyaz sıvalı yuvarlak binası nehirden kolayca seçilir.</p>"},
    stpauls: {k:'Katedral · 1710', t:"St Paul's Katedrali", d:"<p>1666 Büyük Yangını'ndan sonra Christopher Wren'in yeniden yaptığı başyapıt (1710). Kubbesi 250 yıl boyunca Londra'nın en yüksek yapısıydı; Churchill'in cenazesi ve Kral Charles–Diana düğünü burada yapıldı.</p><p><b>Bugün:</b> II. Dünya Savaşı bombardımanında ayakta kalışının fotoğrafı direnişin simgesidir. Nehirden ve Millennium Köprüsü aksından en güzel görünümünü verir.</p>"},
    hmsbelfast: {k:'Savaş gemisi · 1938', t:'HMS Belfast', d:"<p>II. Dünya Savaşı'nın en önemli İngiliz kruvazörlerinden; Normandiya Çıkarması'nda ilk top atışlarını yapan gemilerdendir.</p><p><b>Bugün:</b> 1971'den beri Thames üzerinde yüzen müze; dokuz güvertesi gezilebiliyor (biletli), nehirden silüeti etkileyici.</p>"},
    goldenhinde: {k:'Kalyon kopyası', t:'Golden Hinde', d:"<p>Francis Drake'in 1577-80'de dünyanın çevresini dolaştığı kalyonun tam boy kopyası; orijinali, bu turu tamamlayan ikinci gemiydi.</p><p><b>Bugün:</b> Borough Market'in yanındaki küçük havuzda; dışından 2 dakikalık bakış yeterli, içi biletli.</p>"},
    leadenhall: {k:'Pasaj · 1881', t:'Leadenhall Market', d:"<p>Roma forumunun üzerine kurulmuş, 14. yüzyıldan beri pazar olan alandaki 1881 tarihli görkemli Viktorya pasajı; kırmızı-altın demir işçiliği ve cam çatısıyla.</p><p><b>Bugün:</b> Harry Potter'da <b>Diagon Yolu</b> olarak çekildi; Çatlak Kazan'ın kapısı da buradadır (mavi kapı, Bull's Head Passage).</p>"},
    buckingham: {k:'Saray · 1837\'den beri resmî konut', t:'Buckingham · Changing of the Guard', d:"<p>1703'te konak olarak yapıldı; Kraliçe Victoria'dan (1837) beri hükümdarın resmî Londra konutu. 775 odası var; bayrak direğinde kraliyet sancağı varsa Kral içeridedir.</p><p><b>Nöbet Değişimi:</b> Ayı postu şapkalı muhafızların bando eşliğinde tören devri; 24 Temmuz'da görev 1st Battalion Grenadier Guards'ta, bando Band of the Welsh Guards (11:00, ~45 dk, ücretsiz).</p>"},
    bigben: {k:'Saat kulesi · 1859', t:'Big Ben', d:"<p>Asıl adı Elizabeth Kulesi; Big Ben aslında içindeki 13,7 tonluk büyük çanın adıdır. 1859'dan beri Londra'nın sesi; BBC radyosu saat başlarını hâlâ bu çanla verir.</p><p><b>Bugün:</b> 2017-2022 restorasyonuyla kadranların mavi-altın orijinal renkleri geri döndü. En iyi kare Westminster Köprüsü ve Parliament Square köşesinden.</p>"},
    abbey: {k:'Kilise · 1066\'dan beri taç giyme', t:'Westminster Abbey', d:"<p>1066'dan bu yana tüm İngiliz hükümdarları burada taç giydi; Newton, Darwin, Dickens ve Hawking burada gömülü. Kraliçe Elizabeth'in cenazesi ve William-Kate düğünü de burada yapıldı.</p><p><b>Bugün:</b> Gotik cephesi dışarıdan bile etkileyici; iç gezi biletli ve uzun sürer; bu rotada dıştan bakış yeterli.</p>"},
    eye: {k:'Dönme dolap · 2000', t:'London Eye', d:"<p>Milenyum için yapılan 135 m'lik dev gözlem çarkı; açıldığında dünyanın en yükseğiydi ve 'geçici' olması planlanmıştı; şehrin vazgeçilmez simgesine dönüştü.</p><p><b>Bugün:</b> 32 kapalı kapsülün her biri bir Londra ilçesini temsil eder; tur 30 dk sürer, açık günlerde ~40 km görüş sağlar.</p>"},
    portobello: {k:'Pazar · 1860\'lar', t:'Portobello Road Market', d:"<p>1860'lardan beri kurulan sokak pazarı; dünyanın en büyük antika pazarı olarak bilinir; 2 km boyunca bin kadar tezgâh.</p><p><b>Bugün:</b> Cumartesi ana gündür: antikalar güneyde, yemek ortada, vintage kuzeyde. Pastel evleriyle Notting Hill filminin de sahnesi.</p>"},
    kpalace: {k:'Saray · 1689', t:'Kensington Palace', d:"<p>1689'dan beri kraliyet konutu; Kraliçe Victoria burada doğdu, Prenses Diana 15 yıl burada yaşadı. Bugün Galler Prensi William'ın ailesinin resmî Londra evi.</p><p><b>Bugün:</b> Bahçeleri ve dış cephesi serbest; State Apartments biletli. Önündeki Diana heykeli ve batık bahçe görülmeye değer.</p>"},
    playground: {k:'Oyun alanı · 2000', t:'Diana Memorial Playground', d:"<p>Prenses Diana'nın anısına 2000'de açılan, Peter Pan temalı oyun alanı; yazarı J.M. Barrie bu parkın hemen yanında oturur, hikâyeyi buradaki çocuklara anlatırmış.</p><p><b>Bugün:</b> Dev ahşap korsan gemisi, kumsal ve duyu bahçesiyle Londra'nın en iyi ücretsiz çocuk alanı; yalnızca çocuklu aileler girebilir.</p>"},
    nhm: {k:'Müze · 1881', t:'Doğa Tarihi Müzesi · Natural History Museum', d:"<p>1881 tarihli, katedrali andıran Romanesk binasıyla 'doğanın sarayı'. 80 milyon örneklik koleksiyonun temeli Darwin dönemine uzanır.</p><p><b>Bugün:</b> Girişteki Hintze Hall'da tavandan sarkan 25 m'lik mavi balina iskeleti 'Hope' karşılar; dinozor galerisindeki hareketli T. rex çocukların klasiğidir. Giriş ücretsiz.</p>"},
    science: {k:'Müze · 1857', t:'Science Museum', d:"<p>1857'de Büyük Sergi'nin mirasıyla kuruldu; Stephenson'ın Rocket lokomotifi ve Apollo 10 kapsülü gibi orijinaller burada.</p><p><b>Bugün:</b> Giriş ücretsiz; Wonderlab interaktif galerisi (biletli) büyük çocuklar, bodrumdaki The Garden minikler içindir.</p>"},
    rah: {k:'Konser salonu · 1871', t:'Royal Albert Hall', d:"<p>Kraliçe Victoria'nın eşi Prens Albert'in anısına 1871'de açılan, kırmızı tuğlalı yuvarlak konser salonu; dünyanın en ünlü sahnelerinden.</p><p><b>Bugün:</b> Her yaz BBC Proms festivaline ev sahipliği yapar. Karşısındaki altın kaplama Albert Memorial ile birlikte parkın güney kapısının süsüdür.</p>"},
    fountain: {k:'Anıt çeşme · 2004', t:'Diana Memorial Fountain', d:"<p>Prenses Diana anısına 2004'te açılan, halka biçiminde akan granit çeşme; 'kapsayıcılık' fikriyle çitsiz tasarlandı.</p><p><b>Bugün:</b> Yazın çocukların ayaklarını suya sokması serbesttir; Serpentine gölünün hemen yanında, çimlerde mola için ideal.</p>"},
    hpstudio: {k:'Film stüdyosu', t:'Warner Bros. Studio Tour', d:"<p>Sekiz Harry Potter filminin 10 yıl boyunca çekildiği gerçek Leavesden stüdyoları; setler yıkılmak yerine 2012'de müzeye dönüştürüldü.</p><p><b>Bugün:</b> Gerçek Büyük Salon, Diagon Yolu ve 9¾ Peronu setleri, orijinal kostüm ve aksesuarlarla. Butterbeer yalnızca burada ve parklarda satılır.</p>"},
    cathedral: {k:'Katedral · 1903', t:'Westminster Cathedral', d:"<p>İngiltere'nin ana Katolik katedrali (1903); kırmızı-beyaz çizgili Neo-Bizans mimarisi Londra'da başka hiçbir şeye benzemez; Westminster Abbey ile karıştırılmasın.</p><p><b>Bugün:</b> İçi yarı bitmiş mozaikleriyle loş ve çarpıcıdır; giriş ücretsiz. Victoria İstasyonu'na 5 dk.</p>"},
    kx: {k:'İstasyon · 1852', t:"King's Cross; 9¾ Peronu", d:"<p>J.K. Rowling, Hogwarts Ekspresi'ni gerçek King's Cross'tan (1852) kaldırdı. Filmlerde 9¾ sahneleri bu istasyonun <b>4-5. peronları arasındaki kemerlerde</b> çekildi; o kemerler bilet turnikelerinin arkasındadır; konkorstaki bagaj arabası ise sonradan hayranlar için kurulan resmî fotoğraf enstalasyonudur.</p><p><b>Bugün:</b> Kendi telefonla çekim ücretsizdir (atkı ödünç verilir, kuyruk olabilir); yanında HP Shop. Bitişikteki masalsı kızıl bina St Pancras'tır; filmdeki dış çekimler onundur. Gerçek platform setiyse stüdyo turundadır.</p>"},
    zoo: {k:'Hayvanat bahçesi · 1828', t:'ZSL London Zoo', d:"<p>1828'de kurulan dünyanın en eski bilimsel hayvanat bahçesi; 'zoo' kelimesi buradan türedi. İlk akvaryum, ilk sürüngen evi ve ilk çocuk hayvanat bahçesi de burada açıldı.</p><p><b>Bugün:</b> Sürüngen Evi, ilk Harry Potter filmindeki piton sahnesinin çekildiği yerdir. 2026, kuruluşun 200. yılı.</p>"},
    camden: {k:'Pazar · 1974', t:'Camden Market', d:"<p>1974'te kanal kenarında 16 tezgâhla başladı; bugün haftada 100.000'i aşkın ziyaretçisiyle Londra alternatif kültürünün merkezi. Amy Winehouse'un mahallesiydi; heykeli Stables Market'te.</p><p><b>Bugün:</b> Kanal havzası, at ahırlarından dönüşme çarşılar ve dünya mutfağı tezgâhları; hafta içi çok daha sakin.</p>"},
    primrose: {k:'Tepe · panorama', t:'Primrose Hill', d:"<p>Regent's Park'ın kuzeyindeki 63 m'lik çim tepe; Londra siluetinin korunmuş altı manzara aksından biri; zirve taşında Blake'ten bir dize yazar.</p><p><b>Bugün:</b> Shard'dan Eye'a tüm silüet tek karede; piknik ve gün batımı klasiği.</p>"},
    coventgarden: {k:'Meydan · 1630\'lar', t:'Covent Garden', d:"<p>1630'larda Londra'nın ilk planlı meydanı olarak kuruldu; 300 yıl şehrin sebze-çiçek hali olarak çalıştı (My Fair Lady'nin Eliza'sı burada çiçek satar). 1980'de zarif bir çarşıya dönüştü.</p><p><b>Bugün:</b> Cam çatılı Apple Market, lisanslı sokak sanatçıları ve Kraliyet Operası; Avrupa'nın en iyi sokak gösterisi sahnesi sayılır.</p>"},
    trafalgar: {k:'Meydan · 1844', t:'Trafalgar Square', d:"<p>Nelson'ın 1805 Trafalgar deniz zaferinin anıtı: 52 m'lik sütun ve dört bronz aslan (topların eritilmesiyle döküldü). Londra'nın resmî 'kilometre sıfır' noktasıdır.</p><p><b>Bugün:</b> Dördüncü Kaide'de dönüşümlü çağdaş sanat sergilenir; arkadaki National Gallery ücretsizdir.</p>"},
    shadthames: {k:'Sokak · 19. yy', t:'Shad Thames', d:"<p>Viktorya döneminde 'Londra'nın kileri' denen dev depo sırası; baharat ve çay depoları arasındaki havada asılı demir yük geçitleri olduğu gibi duruyor.</p><p><b>Bugün:</b> Depolar şık dairelere dönüştü ama sokak film seti atmosferini korur; Oliver Twist uyarlamaları burada çekildi.</p>"},
    hamleys: {k:'Oyuncakçı · 1760', t:'Hamleys', d:"<p>1760'ta kurulan, dünyanın en eski ve en ünlü oyuncak mağazası; kraliyet beratlı. II. Dünya Savaşı'nda beş kez bombalandı, beşinde de yeniden açıldı.</p><p><b>Bugün:</b> Regent Street'teki 7 katında canlı oyuncak gösterileri yapılır; alt katta Harry Potter bölümü vardır.</p>"}
  };
  var idB = document.getElementById('idB'), idD = document.getElementById('idD');
  var idT = document.getElementById('idT'), idK = document.getElementById('idK'), idC = document.getElementById('idC');
  function openInfo(key){
    var e = INFO[key]; if(!e) return;
    idK.textContent = e.k; idT.innerHTML = e.t; idC.innerHTML = e.d;
    idB.classList.add('open'); idD.classList.add('open'); idD.scrollTop = 0;
  }
  function closeInfo(){ idB.classList.remove('open'); idD.classList.remove('open'); }
  document.addEventListener('click', function(e){
    var b = e.target.closest('.il');
    if(b){ e.preventDefault(); openInfo(b.getAttribute('data-info')); }
  });
  document.getElementById('idX').addEventListener('click', closeInfo);
  idB.addEventListener('click', closeInfo);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeInfo(); });

  // kalkışa geri sayım (mobil marka satırı)
  var bbc = document.getElementById('bbCount');
  if (bbc) {
    var tripStart = new Date(2026, 6, 23), tripEnd = new Date(2026, 6, 30);
    var now = new Date(); var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    var diff = Math.round((tripStart - today) / 86400000);
    if (diff > 0) bbc.textContent = 'Kalkışa ' + diff + ' gün';
    else if (today <= tripEnd) bbc.textContent = 'Gezinin ' + (Math.round((today - tripStart) / 86400000) + 1) + '. günü';
  }

  // render Lucide icons (fallback for any missing name)
  if(window.lucide && lucide.createIcons){
    try{ lucide.createIcons(); }catch(e){}
  }
  window.addEventListener('load', function(){
    if(window.lucide && lucide.createIcons){ try{ lucide.createIcons(); }catch(e){} }
  });
</script>
</body>
</html>
