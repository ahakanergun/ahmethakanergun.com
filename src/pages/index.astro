---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
  type="website"
>
  <section class="lantern" data-lantern>
    <h1 class="lantern__name" data-lantern-stage>
      <span class="lantern__line">Ahmet</span>
      <span class="lantern__line">Hakan</span>
      <span class="lantern__line lantern__line--italic">Ergün</span>
    </h1>

    <div class="lantern__pointer" data-lantern-pointer aria-hidden="true"></div>

    <p class="lantern__hint" aria-hidden="true">
      <em>karanlıkta gez</em>
    </p>

    <p class="lantern__tagline" aria-hidden="true">
      <em>{SITE.tagline}</em>
    </p>
  </section>
</BaseLayout>

<script>
  const root = document.querySelector<HTMLElement>('[data-lantern]');
  const stage = document.querySelector<HTMLElement>('[data-lantern-stage]');
  const dot = document.querySelector<HTMLElement>('[data-lantern-pointer]');

  if (root && stage) {
    let active = false;
    let idleId = 0;

    const setVars = (xPct: number, yPct: number) => {
      stage.style.setProperty('--mx', `${xPct}%`);
      stage.style.setProperty('--my', `${yPct}%`);
      if (dot) {
        dot.style.setProperty('--mx', `${xPct}%`);
        dot.style.setProperty('--my', `${yPct}%`);
      }
    };

    /* Idle: smooth Lissajous orbit. Two sine waves with different periods
       trace a hypnotic figure-eight path so the light never repeats exactly. */
    const idleOrbit = (ts: number) => {
      const t = ts * 0.00045;
      const x = 50 + Math.cos(t) * 28;
      const y = 50 + Math.sin(t * 0.78) * 26;
      setVars(x, y);
      idleId = requestAnimationFrame(idleOrbit);
    };
    idleId = requestAnimationFrame(idleOrbit);

    const onMove = (e: PointerEvent) => {
      const x = (e.clientX / window.innerWidth) * 100;
      const y = (e.clientY / window.innerHeight) * 100;
      setVars(x, y);
      if (!active) {
        cancelAnimationFrame(idleId);
        idleId = 0;
        root.classList.add('lantern--active');
        active = true;
      }
    };

    // Listen on window so pointer over the header (separate stacking
    // context) also drives the light, and direct write keeps it snappy.
    window.addEventListener('pointermove', onMove, { passive: true });
    window.addEventListener('pointerdown', onMove, { passive: true });
  }
</script>

<style>
  .lantern {
    position: fixed;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 90% 70% at 50% 45%, #14100c 0%, #050402 65%, #020100 100%);
    overflow: hidden;
    cursor: none;
    isolation: isolate;
    touch-action: none;
  }

  .lantern__name {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-rows: 1fr 1fr 1fr;
    place-items: stretch;
    color: #f5ecd9;
    font-family: var(--font);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1;
    text-wrap: nowrap;

    --mx: 50%;
    --my: 50%;
    --r: 22vmin;

    -webkit-mask:
      radial-gradient(circle var(--r) at var(--mx) var(--my),
        rgba(0, 0, 0, 1) 0%,
        rgba(0, 0, 0, 1) 30%,
        rgba(0, 0, 0, 0) 100%);
    mask:
      radial-gradient(circle var(--r) at var(--mx) var(--my),
        rgba(0, 0, 0, 1) 0%,
        rgba(0, 0, 0, 1) 30%,
        rgba(0, 0, 0, 0) 100%);
    will-change: mask, -webkit-mask;
  }

  .lantern__line {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: min(26vw, 32vh);
    text-shadow:
      0 0 28px rgba(255, 220, 160, 0.32),
      0 0 60px rgba(255, 180, 100, 0.18);
    user-select: none;
  }

  .lantern__line--italic {
    font-style: italic;
    font-weight: 400;
    color: #f4c898;
  }

  /* Bigger, more prominent bulb */
  .lantern__pointer {
    position: absolute;
    left: var(--mx, 50%);
    top: var(--my, 50%);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(255, 240, 210, 1);
    box-shadow:
      0 0 0 1px rgba(255, 240, 210, 0.6),
      0 0 22px 6px rgba(255, 210, 150, 0.7),
      0 0 60px rgba(255, 180, 100, 0.4),
      0 0 140px rgba(255, 150, 80, 0.2);
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 2;
  }

  .lantern--active .lantern__pointer {
    opacity: 1;
  }

  .lantern__hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: rgba(245, 236, 217, 0.32);
    margin: 0;
    pointer-events: none;
    animation: hint-pulse 2.8s ease-in-out infinite;
    transition: opacity 600ms;
    z-index: 3;
  }

  .lantern__hint em { font-style: italic; }

  .lantern--active .lantern__hint {
    opacity: 0;
  }

  @keyframes hint-pulse {
    0%, 100% { opacity: 0.22; }
    50%      { opacity: 0.55; }
  }

  .lantern__tagline {
    position: absolute;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font);
    font-style: italic;
    font-size: clamp(0.85rem, 1.2vw, 1.05rem);
    color: rgba(245, 236, 217, 0.32);
    margin: 0;
    letter-spacing: 0.02em;
    pointer-events: none;
    z-index: 3;
  }

  @media (prefers-reduced-motion: reduce) {
    .lantern__name {
      -webkit-mask: none;
      mask: none;
      animation: none;
    }
    .lantern__hint,
    .lantern__pointer {
      display: none;
    }
    .lantern {
      cursor: auto;
    }
  }

  @media (pointer: coarse) {
    .lantern__name {
      --r: 32vmin;
    }
    .lantern {
      cursor: auto;
    }
    .lantern__hint {
      display: none;
    }
  }

  @media (max-aspect-ratio: 3 / 4) {
    .lantern__line {
      font-size: min(36vw, 28vh);
    }
  }
</style>
