---
import { SITE } from '../config';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = path === '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header" data-home={isHome ? '' : undefined}>
  <div class="wrap--x-wide site-header__inner">
    {!isHome && (
      <a class="brand" href="/" aria-label={`${SITE.title} — anasayfa`}>
        <span class="brand__name">{SITE.author}</span>
      </a>
    )}

    <div class="site-header__right">
      <nav class="site-nav" aria-label="Ana menü">
        <ul>
          {SITE.nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      {!isHome && <ThemeToggle />}
    </div>
  </div>
</header>

<style>
  .site-header {
    padding-block: 1.4rem 1rem;
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    transition: background var(--t-base);
  }

  /* On home, the lantern owns the viewport. Header floats over the dark. */
  .site-header[data-home] {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .site-header[data-home] .site-nav a {
    color: rgba(245, 236, 217, 0.55);
  }
  .site-header[data-home] .site-nav a:hover,
  .site-header[data-home] .site-nav a[aria-current='page'] {
    color: #f5ecd9;
  }

  .site-header[data-home] :global(.theme-toggle) {
    border-color: rgba(245, 236, 217, 0.16);
    background: transparent;
    color: rgba(245, 236, 217, 0.55);
  }
  .site-header[data-home] :global(.theme-toggle:hover) {
    color: #f5ecd9;
    border-color: rgba(245, 236, 217, 0.32);
    background: rgba(245, 236, 217, 0.06);
  }


  .site-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .brand {
    color: var(--ink);
    background-image: none;
    padding-bottom: 0;
    font-size: var(--t-1);
    font-weight: 500;
    letter-spacing: -0.018em;
    line-height: 1;
    transition: color var(--t-fast);
  }

  .brand:hover {
    color: var(--accent);
  }

  .site-header__right {
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
    margin-left: auto;
  }

  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.4rem;
  }

  .site-nav a {
    font-size: var(--t-1);
    font-weight: 500;
    letter-spacing: -0.012em;
    color: var(--muted);
    background-image: none;
    position: relative;
    padding-bottom: 0.05em;
    transition: color var(--t-fast);
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.32em;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--t-base);
  }

  .site-nav a:hover,
  .site-nav a[aria-current='page'] {
    color: var(--ink);
  }

  .site-nav a[aria-current='page']::after,
  .site-nav a:hover::after {
    transform: scaleX(1);
  }
</style>
