---
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap--x-wide site-footer__inner">
    <hr class="divider divider--centered" />
    <p class="site-footer__line">
      © {year} {SITE.author}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--s-9);
    padding-bottom: var(--s-7);
  }

  .site-footer__inner {
    text-align: center;
  }

  .site-footer__line {
    font-family: var(--font);
    font-size: var(--t--1);
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
</style>
